    "test:telegram": "tsx src/scripts/test-telegram.ts"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
