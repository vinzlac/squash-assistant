{
  "name": "@squash-assistant/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:mcp": "tsx src/scripts/test-mcp-connections.ts",
    "test:telegram": "tsx src/scripts/test-telegram.ts",
    "test:graph": "tsx src/scripts/test-graph.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-redis": "^1.0.10",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@squash-assistant/db": "*",
    "node-cron": "^3.0.3",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
