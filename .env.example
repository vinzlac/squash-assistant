HUDDLE_BOT_MCP_URL=https://huddle-bot.code-advisors.site/api/mcp
HUDDLE_BOT_MCP_API_KEY=sk_live_...
RESA_SQUASH_MCP_URL=https://resa-squash.vercel.app/api/mcp
RESA_SQUASH_MCP_API_KEY=sk_live_...
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optionnel — seulement pour les tests d'intégration LLM (npm run test:llm côté
# apps/worker, description → paramètres de règle). Absent = ces tests sont skip.
ANTHROPIC_API_KEY=
REDIS_URL=redis://redis.squash-assistant.svc.cluster.local:6379
DATABASE_URL=postgres://squash:squash@postgres.squash-assistant.svc.cluster.local:5432/squash_assistant
# Bootstrap du conteneur Postgres (kubernetes/postgres.yaml) — doit rester identique
# au mot de passe encodé dans DATABASE_URL ci-dessus (deux secrets scellés séparés).
POSTGRES_PASSWORD=
# Utilisé par apps/ui pour appeler l'API interne du worker (apps/worker/src/http/server.ts).
WORKER_INTERNAL_URL=http://squash-assistant.squash-assistant.svc.cluster.local:8080
